;; business-manager — actor manifest (kotoba-native; supersedes actor-manifest.jsonld)
;; Internal operational ERP for etzhayyim producing-actors — double-entry on the kotoba
;; Datom log, audited by toritate 執帳. Salesforce/SAP inversion (internal-only, on-chain).
;; ADR-2606072000 (remediation Phase A of ADR-2606071800)
{:actor/id        "business-manager"
 :actor/glyph     "勘"
 :actor/tier      :tier-b
 :actor/integrates ["okaimono" "toritate" "warifu"]
 :actor/domain    "business-manager.etzhayyim.com"
 :actor/purpose   "Internal operational ERP (general ledger / AP / AR / procurement / budget / HR) for etzhayyim's own producing actors. Double-entry bookkeeping appended to the kotoba Datom log (every entry balances Σdebit=Σcredit by construction), member-signed, audited by toritate. Japanese fiscal year (Apr 1 - Mar 31). Approval: journal >1M JPY, PO >5M JPY. Internal-only (no external tenant/subscription), kotoba-EAVT-native, Murakumo-only."
 :actor/status    :r1
 :actor/adr       "2606072000"
 :actor/supersedes "actor-manifest.jsonld (legacy T1 MCP-Compose / RisingWave-Cypher; deprecated, removed after 1 R-cycle)"

 :actor/charter-rider
 {:rider/version "2.0"
  :rider/applied true}

 :actor/gates
 [{:gate/id "G1"  :gate/name "internal-only"          :gate/rule "ledger serves etzhayyim producing-actors only; NO external tenant, NO billed seats / subscription (no external inflow, §1.3)"}
  {:gate/id "G2"  :gate/name "double-entry-balanced"  :gate/rule "every journal entry balances Σdebit = Σcredit; an unbalanced entry is structurally rejected (not posted)"}
  {:gate/id "G3"  :gate/name "kotoba-eavt-native"     :gate/rule "ledger/PO/budget are append-only kotoba Datoms; no RisingWave/SQL/Cypher (corrects legacy manifest, G6 of ADR-2606071800)"}
  {:gate/id "G4"  :gate/name "no-server-key"          :gate/rule "postings are member-signed (passkey/ERC-4337); business-manager holds no key (ADR-2605231525); server signature refused"}
  {:gate/id "G5"  :gate/name "pii-encrypted-envelope" :gate/rule "employee identifying fields → com.etzhayyim.encrypted.*, DID-bound (ADR-2605181100)"}
  {:gate/id "G6"  :gate/name "approval-thresholds"    :gate/rule "journal entry >1,000,000 JPY and purchase order >5,000,000 JPY route to :approval-required; below = :auto-approved"}
  {:gate/id "G7"  :gate/name "audit-trail-toritate"   :gate/rule "every posting is an append-only Datom forming the audit trail toritate 執帳 attests; no in-place mutation / no delete"}
  {:gate/id "G8"  :gate/name "murakumo-only"          :gate/rule "any narration / report copy via KotobaLLM 127.0.0.1:4000; no external LLM (ADR-2605215000)"}]

 :actor/cells
 [{:cell/id "ledger"   :cell/kind :datalog   :cell/runtime :kotoba :cell/doc "double-entry journal + invoice + employee + budget Datoms"}
  {:cell/id "post"     :cell/kind :langgraph :cell/runtime :wasm   :cell/doc "validate balance (G2) + approval routing (G6) → member-signed posting (G4)"}
  {:cell/id "report"   :cell/kind :langgraph :cell/runtime :wasm   :cell/doc "trial balance / budget vs actual (Murakumo narration, G8)"}]

 :actor/fiscal-year {:start "04-01" :end "03-31" :label "Japanese fiscal year"}

 :actor/approval-thresholds
 {:journal-entry  {:amount 1000000 :currency "JPY"}
  :purchase-order {:amount 5000000 :currency "JPY"}}

 :actor/lexicons
 ["com.etzhayyim.businessManager.journalEntry"
  "com.etzhayyim.businessManager.purchaseOrder"
  "com.etzhayyim.businessManager.invoice"
  "com.etzhayyim.businessManager.employee"
  "com.etzhayyim.businessManager.budgetAllocation"]

 :actor/siblings
 {:toritate "accounting + audit (on-chain) — attests this ledger"
  :okaimono "provisioning (POs may source from okaimono Ring 1)"
  :warifu   "settlement rails for AP"}}
