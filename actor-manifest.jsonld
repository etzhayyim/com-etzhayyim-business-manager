{
  "@context": "https://etzhayyim.com/ns/actor/v1",
  "@id": "did:web:business-manager.etzhayyim.com",
  "approvalThresholds": {
    "journalEntry": {
      "amount": 1000000,
      "currency": "JPY"
    },
    "purchaseOrder": {
      "amount": 5000000,
      "currency": "JPY"
    }
  },
  "capabilities": [
    "graph.query",
    "graph.write",
    "agent.chat",
    "derive:social"
  ],
  "complianceDocs": [
    "90-docs/rules/compliance/per-did-kyumei-shinka-autonomy.md",
    "90-docs/platform/260403-live-data-kyumei-shinka-consolidated.md"
  ],
  "convoSystemPrompt": "You are the Business Manager agent -- corporate ERP intelligence. You manage accounting (General Ledger, Accounts Payable, Accounts Receivable), HR employee records, procurement purchase orders, and budget allocations. Japanese fiscal year (April 1 - March 31). Approval required: journal entries exceeding 1M JPY, purchase orders exceeding 5M JPY. Respond helpfully in the user's language.",
  "description": "Corporate ERP actor for accounting (GL/AP/AR), HR, procurement, and budget management. Japanese fiscal year (March end). Approval thresholds: journal entry >1M JPY, purchase order >5M JPY.",
  "displayName": "Business Manager -- Corporate ERP Intelligence",
  "domainKnowledgeRequired": true,
  "runtime": "k8s-langserver",
  "edge": "sveltekit-proxy",
  "legacyExecutionTier": "T1",
  "fiscalYear": {
    "end": "03-31",
    "label": "Japanese fiscal year",
    "start": "04-01"
  },
  "governance": {
    "classification": "internal",
    "raci": "responsible"
  },
  "graphLabels": [
    "JournalEntry",
    "Invoice",
    "Employee",
    "PurchaseOrder",
    "BudgetAllocation"
  ],
  "heartbeatRequired": true,
  "name": "business-manager",
  "nanoid": "bm4f8k2d1",
  "performerType": "service",
  "pipelines": [
    {
      "steps": [
        {
          "args": {
            "sql": "MATCH (j:JournalEntry) WHERE j.fiscalYear = coalesce($input.fiscalYear, j.fiscalYear) RETURN j.entryId AS entryId, j.debitAccount AS debit, j.creditAccount AS credit, j.amount AS amount, j.currency AS currency, j.description AS description, j.approved AS approved, j.createdAt AS createdAt ORDER BY j.createdAt DESC LIMIT coalesce($input.limit, 50)"
          },
          "fn": "graph.query",
          "id": "listJournals"
        }
      ],
      "trigger": {
        "nsid": "com.etzhayyim.apps.businessManager.listJournalEntries",
        "type": "xrpc"
      }
    },
    {
      "steps": [
        {
          "args": {
            "sql": "RETURN CASE WHEN $input.amount > 1000000 THEN 'approval-required' ELSE 'auto-approved' END AS status LIMIT 1"
          },
          "fn": "graph.query",
          "id": "approvalCheck"
        },
        {
          "args": {
            "template": "CREATE (j:JournalEntry {did: $did, entryId: $input.entryId, debitAccount: $input.debitAccount, creditAccount: $input.creditAccount, amount: $input.amount, currency: coalesce($input.currency, 'JPY'), description: $input.description, fiscalYear: $input.fiscalYear, approved: $approvalCheck.status, repo: $did, collection: 'com.etzhayyim.apps.businessManager.journalEntry'})"
          },
          "fn": "graph.write",
          "id": "writeJournal"
        },
        {
          "args": {
            "message": "You are Business Manager -- Corporate ERP Intelligence. Based on the following new data, write a concise social post (1-2 sentences, informative and specific). Data: $writeJournal.text"
          },
          "depends_on": [
            "writeJournal"
          ],
          "fn": "agent.chat",
          "id": "compose"
        },
        {
          "args": {
            "template": "$compose.text"
          },
          "depends_on": [
            "compose"
          ],
          "fn": "derive:social",
          "id": "announce"
        }
      ],
      "trigger": {
        "nsid": "com.etzhayyim.apps.businessManager.createJournalEntry",
        "type": "xrpc"
      }
    },
    {
      "steps": [
        {
          "args": {
            "sql": "RETURN CASE WHEN $input.amount > 5000000 THEN 'approval-required' ELSE 'auto-approved' END AS status LIMIT 1"
          },
          "fn": "graph.query",
          "id": "poApprovalCheck"
        },
        {
          "args": {
            "template": "CREATE (p:PurchaseOrder {did: $did, poId: $input.poId, vendor: $input.vendor, amount: $input.amount, currency: coalesce($input.currency, 'JPY'), items: $input.items, approved: $poApprovalCheck.status, repo: $did, collection: 'com.etzhayyim.apps.businessManager.purchaseOrder'})"
          },
          "fn": "graph.write",
          "id": "writePO"
        },
        {
          "args": {
            "message": "You are Business Manager -- Corporate ERP Intelligence. Based on the following new data, write a concise social post (1-2 sentences, informative and specific). Data: $writePO.text"
          },
          "depends_on": [
            "writePO"
          ],
          "fn": "agent.chat",
          "id": "compose"
        },
        {
          "args": {
            "template": "$compose.text"
          },
          "depends_on": [
            "compose"
          ],
          "fn": "derive:social",
          "id": "poAnnounce"
        }
      ],
      "trigger": {
        "nsid": "com.etzhayyim.apps.businessManager.createPurchaseOrder",
        "type": "xrpc"
      }
    },
    {
      "steps": [
        {
          "args": {
            "template": "MERGE (i:Invoice {invoiceId: $record.invoiceId}) SET i.vendor = $record.vendor, i.amount = $record.amount, i.currency = coalesce($record.currency, 'JPY'), i.dueDate = $record.dueDate, i.status = 'pending', i.repo = $did, i.collection = 'com.etzhayyim.apps.businessManager.invoice'"
          },
          "fn": "graph.write",
          "id": "processInvoice"
        },
        {
          "args": {
            "message": "You are Business Manager -- Corporate ERP Intelligence. Based on the following new data, write a concise social post (1-2 sentences, informative and specific). Data: $processInvoice.text"
          },
          "depends_on": [
            "processInvoice"
          ],
          "fn": "agent.chat",
          "id": "compose"
        },
        {
          "args": {
            "template": "$compose.text"
          },
          "depends_on": [
            "compose"
          ],
          "fn": "derive:social",
          "id": "invoiceAlert"
        }
      ],
      "trigger": {
        "collection": "com.etzhayyim.apps.businessManager.invoice",
        "type": "subscribeRepos"
      }
    },
    {
      "steps": [
        {
          "args": {
            "sql": "MATCH (b:BudgetAllocation) WHERE b.fiscalYear = $currentFiscalYear RETURN b.department AS department, b.allocated AS allocated, b.spent AS spent, b.remaining AS remaining ORDER BY b.department LIMIT 20"
          },
          "fn": "graph.query",
          "id": "weeklyBudget"
        },
        {
          "args": {
            "sql": "MATCH (i:Invoice {status: 'pending'}) RETURN count(i) AS pendingCount, sum(i.amount) AS pendingTotal LIMIT 1"
          },
          "depends_on": [],
          "fn": "graph.query",
          "id": "pendingInvoices"
        },
        {
          "args": {
            "message": "You are Business Manager -- Corporate ERP Intelligence. Based on the following new data, write a concise social post (1-2 sentences, informative and specific). Data: $pendingInvoices.rows"
          },
          "depends_on": [
            "pendingInvoices"
          ],
          "fn": "agent.chat",
          "id": "compose"
        },
        {
          "args": {
            "template": "$compose.text"
          },
          "depends_on": [
            "compose"
          ],
          "fn": "derive:social",
          "id": "weeklyReport"
        }
      ],
      "trigger": {
        "cron": "0 9 * * 1",
        "type": "cron"
      }
    },
    {
      "steps": [
        {
          "args": {
            "sql": "MATCH (n) WHERE n.repo = $did RETURN count(n) AS nodeCount, coalesce(max(n._seq), 0) AS latestSeq LIMIT 1"
          },
          "fn": "graph.query",
          "id": "coverageNodes"
        },
        {
          "args": {
            "sql": "MATCH (n) WHERE n.repo = $did AND n.collection IS NOT NULL RETURN n.collection AS collection, count(n) AS cnt ORDER BY cnt DESC LIMIT 10"
          },
          "depends_on": [],
          "fn": "graph.query",
          "id": "coverageCollections"
        },
        {
          "args": {
            "params": {
              "actorName": "business-manager",
              "bucket": "6h",
              "collection": "com.etzhayyim.apps.businessmanager.coverageSnapshot",
              "latestSeq": 0,
              "nanoid": "bm4f8k2d1",
              "nodeCount": "$coverageNodes.rows[0].nodeCount"
            },
            "template": "MERGE (c:ActorCoverageSnapshot {actorDid: $did, bucket: $bucket, actorName: $actorName, nanoid: $nanoid, nodeCount: $nodeCount, latestTs: $latestTs, repo: $did, collection: $collection, status: 'active'})"
          },
          "depends_on": [
            "coverageNodes"
          ],
          "fn": "graph.write",
          "id": "coverageSnapshot"
        },
        {
          "args": {
            "message": "You are Business Manager -- Corporate ERP Intelligence. Based on the following new data, write a concise social post (1-2 sentences, informative and specific). Data: $coverageSnapshot.text"
          },
          "depends_on": [
            "coverageSnapshot"
          ],
          "fn": "agent.chat",
          "id": "compose"
        },
        {
          "args": {
            "template": "$compose.text"
          },
          "depends_on": [
            "compose"
          ],
          "fn": "derive:social",
          "id": "announce"
        }
      ],
      "trigger": {
        "cron": "0 */6 * * *",
        "type": "cron"
      }
    },
    {
      "steps": [
        {
          "args": {
            "sql": "MATCH (c:ActorCoverageSnapshot {actorDid: $did}) RETURN c.nodeCount AS nodeCount, c.latestSeq AS latestSeq, c.topCollections AS topCollections, c._seq AS snapshotSeq LIMIT 1"
          },
          "fn": "graph.query",
          "id": "coverageStats"
        },
        {
          "args": {
            "sql": "MATCH (c:ActorCoverageSnapshot {actorDid: $did}) RETURN c.nodeCount AS totalNodes LIMIT 1"
          },
          "depends_on": [],
          "fn": "graph.query",
          "id": "coverageHealth"
        }
      ],
      "trigger": {
        "nsid": "com.etzhayyim.apps.businessmanager.coverage.get",
        "type": "xrpc"
      }
    }
  ],
  "profile": {
    "agentType": "autonomous",
    "capabilities": [
      "accounting-gl",
      "accounts-payable",
      "accounts-receivable",
      "hr-management",
      "procurement",
      "budget-allocation"
    ],
    "description": "ERP management actor. Accounting GL/AP/AR, HR employee records, procurement purchase orders, budget allocation. Japanese fiscal year (April-March). Configurable approval thresholds.",
    "displayName": "Business Manager -- Corporate ERP Intelligence",
    "isBot": true,
    "operator": "etzhayyim.co.jp"
  },
  "requiredCollections": [
    "com.etzhayyim.apps.standard.shinkaEvolution",
    "com.etzhayyim.apps.standard.shinkaKnowledge"
  ],
  "requiredLoops": [
    "shinka",
    "koji",
    "kyumei",
    "domain-knowledge"
  ],
  "standardRule": "per-did-kyumei-shinka-autonomy@2026-04-13",
  "standardStatus": "required",
  "triggers": {
    "subscribeRepos": {
      "collections": [
        "com.etzhayyim.apps.businessManager.journalEntry",
        "com.etzhayyim.apps.businessManager.invoice",
        "com.etzhayyim.apps.businessManager.employee",
        "com.etzhayyim.apps.businessManager.purchaseOrder",
        "com.etzhayyim.apps.businessManager.budgetAllocation"
      ]
    }
  },
  "uiType": "yoro"
}
