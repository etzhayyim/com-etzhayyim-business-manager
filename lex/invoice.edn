[{:db/id -1, :lex.invoice/lexicon 1, :lex.invoice/id "com.etzhayyim.businessManager.invoice", :lex.invoice/defs "{:main {:type \"record\", :key \"tid\", :record {:type \"object\", :required [\"invoiceId\" \"direction\" \"amountMinor\" \"postedBy\"], :properties {:party {:type \"string\", :description \"vendor (AP) or customer (AR); prefer internal okaimono/producing actor\"}, :postedBy {:type \"string\", :description \"member DID (G4)\"}, :settledSig {:type \"string\", :description \"member signature ref on settlement; server sig refused (G4)\"}, :approved {:type \"string\", :description \"DERIVED (G6): auto-approved | approval-required\"}, :amountMinor {:type \"integer\", :description \"JPY minor; > 0; drives approval (G6)\"}, :paymentStatus {:type \"string\", :description \"open | overdue | paid (append-only G7)\"}, :invoiceId {:type \"string\"}, :currency {:type \"string\", :description \"const JPY\"}, :dueDate {:type \"string\", :format \"date\"}, :fiscalYear {:type \"string\"}, :direction {:type \"string\", :description \"payable (AP) | receivable (AR)\"}}}}}"}]