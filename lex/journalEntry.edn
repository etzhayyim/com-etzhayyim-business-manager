[{:db/id -1, :lex.journalEntry/lexicon 1, :lex.journalEntry/id "com.etzhayyim.businessManager.journalEntry", :lex.journalEntry/defs "{:main {:type \"record\", :key \"tid\", :record {:type \"object\", :required [\"entryId\" \"lines\" \"fiscalYear\" \"postedBy\"], :properties {:description {:type \"string\"}, :postedBy {:type \"string\", :description \"member DID that signed the posting (G4)\"}, :postedSig {:type \"string\", :description \"member signature ref; server signature refused (G4)\"}, :entryId {:type \"string\"}, :lines {:type \"array\", :description \"≥2 balanced lines; Σ debitMinor = Σ creditMinor (G2)\", :items {:type \"object\", :required [\"account\" \"debitMinor\" \"creditMinor\"], :properties {:account {:type \"string\", :description \"chart-of-accounts code\"}, :debitMinor {:type \"integer\", :description \"JPY minor; one of debit/credit is 0\"}, :creditMinor {:type \"integer\"}}}}, :approved {:type \"string\", :description \"DERIVED (G6): auto-approved | approval-required — never caller-set\"}, :amountMinor {:type \"integer\", :description \"entry magnitude (Σdebit) — drives approval threshold (G6)\"}, :currency {:type \"string\", :description \"const JPY (internal ledger)\"}, :fiscalYear {:type \"string\", :description \"JP fiscal year label, e.g. FY2026 (Apr 1 2026 - Mar 31 2027)\"}, :appendOnly {:type \"boolean\", :description \"const true — no mutation/delete; audit trail for toritate (G7)\"}}}}}"}]
